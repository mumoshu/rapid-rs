+++ b/rapid/src/main/java/com/vrg/rapid/messaging/impl/NdjsonTraceWriter.java
@@ -0,0 +1,71 @@
+/*
+ * rapid-rs interop helper — appends one NDJSON record per received
+ * RapidRequest to the file named by env var RAPID_NDJSON_TRACE.
+ *
+ * Schema: {"ts_ms": <long>, "dst": "host:port", "req_b64": "<base64>"}
+ *
+ * Best-effort: any IO error silently disables further writes.
+ */
+package com.vrg.rapid.messaging.impl;
+
+import com.vrg.rapid.pb.Endpoint;
+import com.vrg.rapid.pb.RapidRequest;
+
+import java.io.BufferedWriter;
+import java.io.IOException;
+import java.nio.charset.StandardCharsets;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.nio.file.Paths;
+import java.nio.file.StandardOpenOption;
+import java.util.Base64;
+import java.util.concurrent.atomic.AtomicBoolean;
+
+final class NdjsonTraceWriter {
+    private static final AtomicBoolean disabled = new AtomicBoolean(false);
+    private static final Path path = resolvePath();
+    private static final Object lock = new Object();
+    private static BufferedWriter writer;
+
+    private NdjsonTraceWriter() {
+    }
+
+    private static Path resolvePath() {
+        final String env = System.getenv("RAPID_NDJSON_TRACE");
+        if (env == null || env.isEmpty()) {
+            disabled.set(true);
+            return null;
+        }
+        return Paths.get(env);
+    }
+
+    static void write(final Endpoint address, final RapidRequest request) {
+        if (disabled.get()) {
+            return;
+        }
+        try {
+            synchronized (lock) {
+                if (writer == null) {
+                    writer = Files.newBufferedWriter(
+                            path,
+                            StandardCharsets.UTF_8,
+                            StandardOpenOption.CREATE,
+                            StandardOpenOption.APPEND,
+                            StandardOpenOption.WRITE);
+                }
+                final String dst = address.getHostname().toStringUtf8() + ":" + address.getPort();
+                final String b64 = Base64.getEncoder().encodeToString(request.toByteArray());
+                writer.write("{\"ts_ms\":");
+                writer.write(Long.toString(System.currentTimeMillis()));
+                writer.write(",\"dst\":\"");
+                writer.write(dst);
+                writer.write("\",\"req_b64\":\"");
+                writer.write(b64);
+                writer.write("\"}\n");
+                writer.flush();
+            }
+        } catch (final IOException e) {
+            disabled.set(true);
+        }
+    }
+}
